  "keyFeatures": [
    "Multi-tenant scraping job management across Instagram, TikTok, Threads, and X",
    "Automated follower scraping with gender-based filtering",
    "Campaign creation and lifecycle management (14,400 profiles per campaign)",
    "Automated distribution to 80 virtual assistants via Airtable",
    "Real-time progress tracking and status monitoring",
    "Supabase integration with Row-Level Security for multi-tenant isolation",
    "Source profile management and deduplication",
    "7-day campaign cleanup automation"
  ],
  "publicApiSurface": [
    "POST /api/scrape-followers - Scrape Instagram followers from source accounts",
    "POST /api/ingest - Ingest scraped profiles into database",
    "POST /api/daily-selection - Create campaign and select 14,400 profiles",
    "POST /api/distribute/{campaign_id} - Distribute profiles to VA tables",
    "POST /api/airtable-sync/{campaign_id} - Sync profiles to Airtable",
    "POST /api/cleanup - Cleanup 7-day old campaigns",
    "createScrapingJob() - Create a new scraping job",
    "getActiveJob() - Get the active scraping job",
    "getJobStatisticsByBaseId() - Get job statistics by base ID",
    "apiPost() - Make authenticated API POST request with base_id",
    "apiGet() - Make authenticated API GET request with base_id",
    "createSupabaseClientWithContext() - Create Supabase client with RLS context"
  ]
}
